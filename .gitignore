/target/
# Ignore the contents of .memhub/ (machine-local state) but allow the
# tracked canonical config example through. Using `/.memhub/*` instead
# of `/.memhub/` keeps the directory itself visible to git so the
# `!` re-include below can match.
/.memhub/*
!/.memhub/config.example.toml
agent_docs/PROJECT.md
agent_docs/PROJECT_LEDGER.md
/review_runs/
/.claude/
__pycache__/
agent_docs/PROJECT.md
agent_docs/PROJECT_LEDGER.md
# macOS Finder metadata
.DS_Store
